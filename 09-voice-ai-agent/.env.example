# OpenAI API key for Whisper STT, GPT LLM, and TTS
# If not set, the system will use mock implementations
OPENAI_API_KEY=

# LIVE mode only: path to a real audio file (.wav/.mp3/.m4a) for Whisper to
# transcribe. Required when OPENAI_API_KEY is set - the bundled text fixture is
# not audio. Ignored in mock mode.
AUDIO_INPUT_PATH=

# Optional: ElevenLabs API key for alternative TTS
# (Not used in v1, but included for future extension)
ELEVENLABS_API_KEY=
